# BasicMetadataFlow

main: kit: flow: BasicMetadataFlow:
{
  entity: "metadata",
  kind: "basic",
  name: "BasicMetadataFlow",
  step: [
    {
      input: {
        ref: "metadata_ref01",
        srcdatavar: "metadata_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-metadata_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicMetadataFlow"
}